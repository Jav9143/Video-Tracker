# ─── Copia este archivo a .env y rellena los valores ───
#
# MONGODB ATLAS:
#   1. Ve a https://cloud.mongodb.com → crea cuenta gratis
#   2. Crea un cluster gratuito (M0)
#   3. En "Connect" → "Drivers" → copia el connection string
#   4. Reemplaza <password> con tu contraseña real
#
MONGO_URL="mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="video_tracker"

# JWT: pon cualquier cadena larga y aleatoria (mínimo 32 caracteres)
JWT_SECRET="cambia_esto_por_una_clave_segura_minimo_32_chars"

# CORS: pon la URL de tu frontend en Vercel (sin barra al final)
# Ejemplo: CORS_ORIGINS="https://video-tracker.vercel.app"
CORS_ORIGINS="*"
